" -----------------------------------------------------------------------------
" GENERAL SETTINGS
" -----------------------------------------------------------------------------
set nocompatible
filetype plugin indent on
syntax enable
set cursorline
set showcmd
set wildmenu
set wildmode=longest:full,full
set laststatus=2
set confirm
set number
set relativenumber
set hlsearch
set incsearch
set ignorecase
set smartcase

" -----------------------------------------------------------------------------
" INDENTATION DEFAULTS
" -----------------------------------------------------------------------------
set tabstop=4
set shiftwidth=4
set expandtab

